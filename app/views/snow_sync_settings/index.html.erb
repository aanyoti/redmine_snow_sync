<h2>ServiceNow Sync</h2>

<%# ── Status bar ─────────────────────────────────────────────────────── %>
<div class="box" style="display:flex; gap:24px; align-items:center; padding:12px 16px;">
  <div>
    <strong>Last sync:</strong>
    <%= @settings['last_sync_at'].present? ? Time.parse(@settings['last_sync_at']).strftime('%Y-%m-%d %H:%M %Z') : 'Never' %>
  </div>
  <div>
    <strong>Total synced:</strong> <%= @stats[:total] %>
    &nbsp;|&nbsp;
    <span style="color:green;"><strong>OK:</strong> <%= @stats[:ok] %></span>
    &nbsp;|&nbsp;
    <span style="color:#c22;"><strong>Errors:</strong> <%= @stats[:errors] %></span>
  </div>
  <div style="margin-left:auto;">
    <button id="run-now-btn" class="button">&#9654; Sync Now</button>
    <span id="run-now-status" style="margin-left:10px; font-style:italic;"></span>
  </div>
</div>

<%# ── Settings form ──────────────────────────────────────────────────── %>
<%= form_tag snow_sync_settings_path, method: :post do %>
  <div class="box tabular">
    <h3>ServiceNow Connection</h3>
    <p>
      <label>Instance URL</label>
      <%= text_field_tag 'settings[snow_url]', @settings['snow_url'], class: 'wide', id: 'snow_url' %>
    </p>
    <p>
      <label>Username</label>
      <%= text_field_tag 'settings[snow_username]', @settings['snow_username'], class: 'wide',
          id: 'snow_username', autocomplete: 'off' %>
    </p>
    <p>
      <label>Password</label>
      <%= password_field_tag 'settings[snow_password]', @settings['snow_password'], class: 'wide',
          id: 'snow_password', autocomplete: 'new-password' %>
    </p>
    <p>
      <label>&nbsp;</label>
      <button type="button" id="test-conn-btn" class="button">&#10003; Test Connection</button>
      <span id="test-conn-result" style="margin-left:10px; font-weight:bold;"></span>
    </p>
    <p style="color:#888; font-size:0.85em; margin-top:-6px;">
      <em>Try each account (GetRestUser / WebServiceUser) — enter credentials above and click Test before saving.</em>
    </p>
  </div>

  <div class="box tabular">
    <h3>Sync Target</h3>
    <p>
      <label>Redmine Project</label>
      <%= select_tag 'settings[target_project_id]',
            options_from_collection_for_select(@projects, :id, :name, @settings['target_project_id'].to_i) %>
    </p>
    <p>
      <label>Tracker</label>
      <%= select_tag 'settings[target_tracker_id]',
            options_from_collection_for_select(@trackers, :id, :name, @settings['target_tracker_id'].to_i) %>
    </p>
  </div>

  <div class="box tabular">
    <h3>ServiceNow Filters</h3>
    <p>
      <label>Assignment Groups <em style="font-weight:normal;">(comma-separated)</em></label>
      <%= text_field_tag 'settings[assignment_groups]', @settings['assignment_groups'], class: 'wide' %>
    </p>
    <p>
      <label>Request States <em style="font-weight:normal;">(comma-separated raw codes; leave blank to skip filter)</em></label>
      <%= text_field_tag 'settings[poll_states]', @settings['poll_states'] %>
      <em class="info">1 = Open &nbsp; 2 = Work in Progress &nbsp; 3 = Closed Complete</em>
    </p>
    <p>
      <label>Service Delivery Stage <em style="font-weight:normal;">(comma-separated; leave blank to skip filter)</em></label>
      <%= text_field_tag 'settings[poll_delivery_stage]', @settings['poll_delivery_stage'], class: 'wide' %>
      <em class="info">e.g. <strong>Awaiting acceptance</strong> &nbsp; or &nbsp; Awaiting acceptance,Installation</em>
    </p>
    <p>
      <label>Only import requests created in the last</label>
      <%= text_field_tag 'settings[days_back]', @settings['days_back'], size: 4 %> days
      <em class="info">Set to 0 to import all matching requests (no date limit)</em>
    </p>
    <p>
      <label>Exchange Rate (1 USD =)</label>
      <%= text_field_tag 'settings[zmw_usd_rate]', @settings['zmw_usd_rate'], size: 8 %> ZMW
      &nbsp;
      <button type="button" id="recalc-rate-btn" class="button">&#8635; Recalculate all orders</button>
      <span id="recalc-rate-status" style="margin-left:8px; font-style:italic;"></span>
      <br><em class="info">Save the new rate first, then click Recalculate to update NRR/MRR on all existing orders immediately.</em>
    </p>
  </div>

  <div class="box tabular">
    <h3>ServiceNow Field Names <em style="font-weight:normal; font-size:0.85em;">(adjust if your instance uses different API names)</em></h3>
    <p>
      <label>Account field</label>
      <%= text_field_tag 'settings[field_account]', @settings['field_account'] %>
      <em class="info">e.g. u_account or company</em>
    </p>
    <p>
      <label>Order field</label>
      <%= text_field_tag 'settings[field_order]', @settings['field_order'] %>
      <em class="info">e.g. u_order</em>
    </p>
    <p>
      <label>Service field</label>
      <%= text_field_tag 'settings[field_service]', @settings['field_service'] %>
      <em class="info">e.g. u_service or service_offering</em>
    </p>
  </div>

  <div class="box tabular">
    <h3>Salesforce Webhook</h3>
    <p>
      <label>Webhook URL <em style="font-weight:normal;">(read-only)</em></label>
      <input type="text" value="<%= request.base_url %>/api/snow_sync/segments"
             class="wide" readonly style="background:#f5f5f5; color:#555; cursor:text;">
      <em class="info">POST this URL from Power Automate with your token in the <code>X-Webhook-Token</code> header</em>
    </p>
    <p>
      <label>Webhook Token <span class="required">*</span></label>
      <input type="text" id="webhook_token_field"
             name="settings[webhook_token]"
             value="<%= @settings['webhook_token'] %>"
             class="wide" style="font-family:monospace;" autocomplete="off">
      <button type="button" id="gen-token-btn" class="button" style="margin-left:6px;">&#8635; Generate</button>
      <em class="info">Copy this value into the <code>X-Webhook-Token</code> header in your Power Automate HTTP action. Save settings after generating.</em>
    </p>
    <p>
      <label>Opportunity Type → Tracker map</label>
      <%= text_field_tag 'settings[opportunity_tracker_map]', @settings['opportunity_tracker_map'], class: 'wide' %>
      <em class="info">Format: <code>New Business:14,Renewal:14,Upgrade:14,Change:14,Downgrade:14</code> — use tracker IDs</em>
    </p>
    <p>
      <label>Teams Power Automate Webhook URL</label>
      <%= text_field_tag 'settings[teams_webhook_url]', @settings['teams_webhook_url'], class: 'wide', placeholder: 'https://prod-xx.westeurope.logic.azure.com/workflows/...' %>
      <em class="info">Power Automate HTTP trigger URL — receives event payloads for Teams adaptive card notifications</em>
    </p>
    <p>
      <label>Teams Test Recipient Email</label>
      <%= text_field_tag 'settings[teams_test_email]', @settings['teams_test_email'], class: 'wide', placeholder: 'anthony.anyoti@liquidtelecom.com' %>
      <em class="info">When set, ALL Teams notifications are also sent to this address — use during testing, clear when live</em>
    </p>
  </div>

  <%# ── LibreNMS Integration ───────────────────────────────────────────── %>
  <div class="box tabular">
    <h3>LibreNMS Integration</h3>
    <p>
      <label>LibreNMS URL <em style="font-weight:normal;">(read-only)</em></label>
      <input type="text" value="https://librenms.liquidtelecom.zm" class="wide" readonly
             style="background:#f5f5f5; color:#555; cursor:text;">
    </p>
    <p>
      <label>API Token <span class="required">*</span></label>
      <input type="password" id="librenms_token_field"
             name="settings[librenms_token]"
             value="<%= @settings['librenms_token'] %>"
             class="wide" style="font-family:monospace;" autocomplete="new-password">
      <button type="button" id="librenms-token-toggle" class="button" style="margin-left:6px;" title="Show/hide token">&#128065;</button>
      <em class="info">
        Get this from LibreNMS: <strong>Settings &rarr; API &rarr; API Settings &rarr; Create API token</strong>
      </em>
    </p>
    <p>
      <label>&nbsp;</label>
      <button type="button" id="librenms-test-btn" class="button">&#10003; Test Connection</button>
      <span id="librenms-test-result" style="margin-left:10px; font-weight:bold;"></span>
    </p>
    <p style="color:#888; font-size:0.85em; margin-top:-4px;">
      <em>Provides device/port autocomplete on Commercial Orders and C2 issue edit forms (Core, Aggregation &amp; Metro Routers).</em>
    </p>
  </div>

  <%# ── SLA Targets ──────────────────────────────────────────────────── %>
  <div class="box tabular">
    <h3>SLA Targets &amp; MTTI Goal</h3>
    <p style="color:#666; font-size:0.9em; margin-bottom:12px;">
      Set the target days for each status. The running total shows how your targets add up against the MTTI goal.
      Hold statuses are excluded — they pause the clock automatically.
    </p>

    <p>
      <label>MTTI Goal (days)</label>
      <%= text_field_tag 'settings[mtti_target]', @mtti_target, size: 4, id: 'mtti_target' %>
      <em class="info">Overall installation target — used as the reference line in reports</em>
    </p>

    <div style="display:flex; gap:32px; flex-wrap:wrap; margin-top:8px;">

      <%# Commercial Orders %>
      <div style="flex:1; min-width:280px;">
        <h4 style="margin-bottom:8px;">Commercial Orders
          &nbsp;<span id="commercial-total-badge" style="font-size:0.82em; padding:2px 8px; border-radius:10px; font-weight:bold;"></span>
        </h4>
        <table style="width:100%; border-collapse:collapse; font-size:0.9em;">
          <% @commercial_statuses.each do |status_name| %>
            <tr>
              <td style="padding:4px 6px;"><%= status_name %></td>
              <td style="padding:4px 6px; width:70px;">
                <%= number_field_tag "sla_days[#{status_name}]",
                      @sla_days[status_name],
                      min: 0, max: 999, step: 1,
                      size: 4,
                      class: 'sla-day-input commercial-day',
                      style: 'width:56px; text-align:right;' %>
                <span style="color:#888; font-size:0.85em;">d</span>
              </td>
            </tr>
          <% end %>
        </table>
      </div>

      <%# C2 %>
      <div style="flex:1; min-width:280px;">
        <h4 style="margin-bottom:8px;">C2
          &nbsp;<span id="c2-total-badge" style="font-size:0.82em; padding:2px 8px; border-radius:10px; font-weight:bold;"></span>
        </h4>
        <table style="width:100%; border-collapse:collapse; font-size:0.9em;">
          <% @c2_statuses.each do |status_name| %>
            <tr>
              <td style="padding:4px 6px;"><%= status_name %></td>
              <td style="padding:4px 6px; width:70px;">
                <%= number_field_tag "sla_days[#{status_name}]",
                      @sla_days[status_name],
                      min: 0, max: 999, step: 1,
                      size: 4,
                      class: 'sla-day-input c2-day',
                      style: 'width:56px; text-align:right;' %>
                <span style="color:#888; font-size:0.85em;">d</span>
              </td>
            </tr>
          <% end %>
        </table>
      </div>

    </div>
  </div>

  <p><%= submit_tag 'Save Settings' %></p>
<% end %>

<%# ── Recent sync log ────────────────────────────────────────────────── %>
<h3>Recent Sync Log</h3>
<% if @records.any? %>
  <table class="list">
    <thead>
      <tr>
        <th>SNow Request #</th>
        <th>Redmine Issue</th>
        <th>Status</th>
        <th>Synced At</th>
        <th>Error</th>
      </tr>
    </thead>
    <tbody>
      <% @records.each_with_index do |r, i| %>
        <tr class="<%= cycle('odd','even') %>">
          <td>
            <a href="https://oneliquidsupport.service-now.com/nav_to.do?uri=sc_request.do?sys_id=<%= r.snow_sys_id %>"
               target="_blank"><%= r.snow_number %></a>
          </td>
          <td>
            <% if r.issue_id %>
              <%= link_to "##{r.issue_id}", issue_path(r.issue_id) %>
            <% end %>
          </td>
          <td style="color:<%= r.sync_status == 'ok' ? 'green' : '#c22' %>;">
            <%= r.sync_status %>
          </td>
          <td><%= r.synced_at&.strftime('%Y-%m-%d %H:%M') %></td>
          <td style="color:#c22; font-size:0.85em;"><%= r.sync_error %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="nodata">No sync records yet. Click "Sync Now" to run the first import.</p>
<% end %>

<script>
// ── Generate Token ────────────────────────────────────────────────────────
document.getElementById('gen-token-btn').addEventListener('click', function() {
  var arr = new Uint8Array(32);
  window.crypto.getRandomValues(arr);
  var token = Array.from(arr).map(function(b){ return b.toString(16).padStart(2,'0'); }).join('');
  document.getElementById('webhook_token_field').value = token;
});

// ── Test Connection ───────────────────────────────────────────────────────
document.getElementById('test-conn-btn').addEventListener('click', function() {
  var btn    = this;
  var result = document.getElementById('test-conn-result');
  var csrf   = document.querySelector('meta[name="csrf-token"]').content;

  btn.disabled     = true;
  result.style.color = '#555';
  result.textContent = 'Testing…';

  var body = new URLSearchParams({
    url:      document.getElementById('snow_url').value,
    username: document.getElementById('snow_username').value,
    password: document.getElementById('snow_password').value,
    authenticity_token: csrf
  });

  fetch('<%= snow_sync_test_connection_path %>', {
    method:  'POST',
    headers: { 'Accept': 'application/json', 'Content-Type': 'application/x-www-form-urlencoded' },
    body:    body.toString()
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    result.style.color = data.ok ? 'green' : '#c22';
    result.textContent = data.message;
    btn.disabled = false;
  })
  .catch(function(err) {
    result.style.color = '#c22';
    result.textContent = 'Request failed: ' + err;
    btn.disabled = false;
  });
});

// ── SLA target running totals ─────────────────────────────────────────────
function updateSlaTotals() {
  var goal = parseInt(document.getElementById('mtti_target').value) || 15;

  function sumAndBadge(selector, badgeId) {
    var total = 0;
    document.querySelectorAll(selector).forEach(function(el) {
      total += parseInt(el.value) || 0;
    });
    var badge = document.getElementById(badgeId);
    var over  = total > goal;
    badge.textContent  = total + 'd / ' + goal + 'd target';
    badge.style.background  = over ? '#fdf0ef' : '#f0faf4';
    badge.style.color       = over ? '#c0392b' : '#27ae60';
    badge.style.border      = '1px solid ' + (over ? '#e5b4b0' : '#b4dfc4');
  }

  sumAndBadge('.commercial-day', 'commercial-total-badge');
  sumAndBadge('.c2-day',         'c2-total-badge');
}

document.querySelectorAll('.sla-day-input').forEach(function(el) {
  el.addEventListener('input', updateSlaTotals);
});
document.getElementById('mtti_target').addEventListener('input', updateSlaTotals);
updateSlaTotals();

// ── Recalculate exchange rates ────────────────────────────────────────────
document.getElementById('recalc-rate-btn').addEventListener('click', function() {
  var btn    = this;
  var status = document.getElementById('recalc-rate-status');
  btn.disabled     = true;
  status.style.color = '#555';
  status.textContent = 'Recalculating…';

  fetch('<%= snow_sync_recalculate_rates_path %>', {
    method:  'POST',
    headers: {
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
      'Accept':       'application/json'
    }
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    status.style.color = 'green';
    status.textContent = 'Done — ' + data.updated + ' order(s) updated at rate ' + data.rate + ' (skipped: ' + data.skipped + ')';
    btn.disabled = false;
  })
  .catch(function(err) {
    status.style.color = '#c22';
    status.textContent = 'Failed: ' + err;
    btn.disabled = false;
  });
});

// ── LibreNMS token show/hide ──────────────────────────────────────────────
document.getElementById('librenms-token-toggle').addEventListener('click', function() {
  var f = document.getElementById('librenms_token_field');
  f.type = f.type === 'password' ? 'text' : 'password';
});

// ── LibreNMS test connection ──────────────────────────────────────────────
document.getElementById('librenms-test-btn').addEventListener('click', function() {
  var btn    = this;
  var result = document.getElementById('librenms-test-result');
  var token  = document.getElementById('librenms_token_field').value.trim();

  if (!token) {
    result.style.color = '#c22';
    result.textContent = 'Enter a token first.';
    return;
  }

  btn.disabled       = true;
  result.style.color = '#555';
  result.textContent = 'Testing…';

  fetch('<%= snow_libre_nms_devices_path %>?q=pe', {
    headers: { 'X-Redmine-API-Key': '', 'Accept': 'application/json',
               'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content }
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    if (Array.isArray(data) && data.length >= 0) {
      result.style.color = 'green';
      result.textContent = '&#10003; Connected — ' + data.length + ' device(s) matched for "pe". Token is working.';
    } else {
      result.style.color = '#c22';
      result.textContent = 'Unexpected response: ' + JSON.stringify(data).substring(0, 80);
    }
    btn.disabled = false;
  })
  .catch(function(err) {
    result.style.color = '#c22';
    result.textContent = 'Request failed: ' + err;
    btn.disabled = false;
  });
});

// ── Sync Now ──────────────────────────────────────────────────────────────
document.getElementById('run-now-btn').addEventListener('click', function(e) {
  e.preventDefault();
  var btn    = this;
  var status = document.getElementById('run-now-status');
  btn.disabled = true;
  status.textContent = 'Running…';

  fetch('<%= snow_sync_run_now_path %>', {
    method:  'POST',
    headers: {
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content,
      'Accept':       'application/json'
    }
  })
  .then(function(r) { return r.json(); })
  .then(function(data) {
    var msg = 'Imported: ' + data.imported + '  Skipped: ' + data.skipped;
    if (data.errors && data.errors.length) msg += '  Errors: ' + data.errors.join('; ');
    status.textContent = msg;
    btn.disabled = false;
    // Reload page after short delay to refresh log table
    setTimeout(function() { location.reload(); }, 2000);
  })
  .catch(function(err) {
    status.textContent = 'Request failed: ' + err;
    btn.disabled = false;
  });
});
</script>
