<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body     { font-family: Arial, sans-serif; font-size: 14px; color: #333; margin: 0; padding: 0; }
    .wrapper { max-width: 600px; margin: 0 auto; padding: 24px; }
    .header  { background: #273c88; color: #fff; padding: 16px 20px; border-radius: 4px 4px 0 0; }
    .header h2 { margin: 0; font-size: 18px; }
    .body    { border: 1px solid #ddd; border-top: none; padding: 24px; border-radius: 0 0 4px 4px; }
    .facts   { width: 100%; border-collapse: collapse; margin: 16px 0; }
    .facts td { padding: 8px 12px; border-bottom: 1px solid #f0f0f0; font-size: 13px; }
    .facts td:first-child { font-weight: bold; color: #555; width: 100px; }
    .btn     { display: inline-block; padding: 12px 28px; background: #273c88; color: #fff !important;
               text-decoration: none; border-radius: 4px; font-size: 14px; font-weight: bold; margin-top: 20px; }
    .note    { background: #f8f8f8; border-left: 4px solid #273c88; padding: 12px 16px;
               margin: 16px 0; font-size: 13px; line-height: 1.6; }
    .footer  { font-size: 11px; color: #999; margin-top: 20px; border-top: 1px solid #eee; padding-top: 10px; }
  </style>
</head>
<body>
<div class="wrapper">

  <div class="header">
    <h2>&#128274; Liquid IT Projects Portal</h2>
  </div>

  <div class="body">
    <p>Dear <%= @user_name %>,</p>

    <% if @ldap %>
      <p>You have been granted access to the <strong>Liquid IT Projects Portal</strong>. Use the details below to sign in with your standard Active Directory password.</p>
    <% else %>
      <p>Your account has been created on the <strong>Liquid IT Projects Portal</strong>. Please use the credentials below to sign in.</p>
    <% end %>

    <table class="facts">
      <tr><td>Username</td><td><strong><%= @login %></strong></td></tr>
      <% unless @ldap %>
        <tr><td>Password</td><td><strong><%= @password %></strong></td></tr>
      <% end %>
      <% if @ldap %>
        <tr><td>Password</td><td>Your standard Liquid / Airtel AD password</td></tr>
      <% end %>
    </table>

    <% unless @ldap %>
      <div class="note">
        Please change your password after your first sign-in.
      </div>
    <% end %>

    <a href="<%= @portal_url %>" class="btn">Log in to the Portal</a>

    <p style="margin-top:20px; font-size:13px; color:#555;">
      If the button above does not work, copy and paste this address into your browser:<br>
      <span style="color:#273c88;"><%= @portal_url %></span>
    </p>
  </div>

  <div class="footer">
    Liquid IT Zambia &mdash; This is an automated notification. Please do not reply to this email.
  </div>

</div>
</body>
</html>
